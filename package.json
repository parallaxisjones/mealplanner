		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^26.1.1",
		"@vite-pwa/sveltekit": "^1.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.110.0"
	},
	"dependencies": {
		"@automerge/automerge": "^3.2.6",
		"@automerge/automerge-repo": "^2.5.6",
		"@automerge/automerge-repo-storage-indexeddb": "^2.5.6",
